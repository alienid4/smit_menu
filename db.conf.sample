# =============================================================================
# /TWLog/AI/conf/db.conf   — 每台主機自己一份
# =============================================================================
# 用途：告訴 mod_db.sh / mod_troubleshoot.sh 這台機器上的 DB 環境。
#
# 規則：
#   1. 密碼「絕對不寫這裡」，改指向各 DB 原生認證檔
#   2. <DB>_ENABLE = auto / yes / no
#        auto = 靠自動偵測決定要不要跑 (預設)
#        no   = 該台明確不跑此 DB (即使偵測到也略過)
#   3. 此檔建議 chmod 600，並納入 Ansible / 組態管理
# =============================================================================

# --- Oracle ---
# sqlplus /@APPDB   (TNS alias, 靠 wallet 或 tnsnames.ora 認證)
ORACLE_ENABLE="auto"
ORACLE_TNS_ALIAS="APPDB"

# --- MSSQL ---
# MSSQL_CRED_FILE 格式 (chmod 600):
#   USER=healthcheck
#   PASSWORD=xxx
MSSQL_ENABLE="auto"
MSSQL_HOST="localhost"
MSSQL_PORT=1433
MSSQL_USER="healthcheck"
MSSQL_CRED_FILE="/root/.mssqlrc"

# --- MySQL / MariaDB ---
# MySQL 原生認證檔 ~/.my.cnf, [client] section, chmod 600
#   [client]
#   user=healthcheck
#   password=xxx
MYSQL_ENABLE="auto"
MYSQL_CRED_FILE="/root/.my.cnf"
MYSQL_REPLICA_LAG_WARN=60
MYSQL_REPLICA_LAG_FAIL=300

# --- DB2 ---
# DB2_CRED_FILE 格式 (chmod 600):
#   USER=db2inst1
#   PASSWORD=xxx
DB2_ENABLE="auto"
DB2_INSTANCE="db2inst1"
DB2_DATABASE="APPDB"
DB2_CRED_FILE="/root/.db2creds"

# --- PostgreSQL ---
# 密碼放 ~/.pgpass (chmod 600)，格式:  host:port:db:user:password
PG_ENABLE="auto"
PG_HOST="localhost"
PG_PORT=5432
PG_USER="healthcheck"
PG_REPLICA_LAG_WARN=60
PG_REPLICA_LAG_FAIL=300

# --- MongoDB ---
# MONGO_URI_FILE: chmod 600，單行連線字串，例：
#   mongodb://healthcheck:xxx@localhost:27017/?authSource=admin
MONGO_ENABLE="auto"
MONGO_URI_FILE="/root/.mongo_uri"
